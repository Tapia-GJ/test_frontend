generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role{
  USER
  ADMIN
}

model User {
  id    Int     @id @default(autoincrement())
  email String  
  password String?
  name  String?
  age Int
  role Role
  createdAt DateTime @default(now())
  auditLog AuditLog[]
  @@unique([email])
}

model AuditLog {
     id         Int      @id @default(autoincrement())
     action     String  
     entityId   Int     
     actorId    Int     
     actor      User     @relation(fields: [actorId], references: [id])
     details    Json?   
     createdAt  DateTime @default(now())
   }