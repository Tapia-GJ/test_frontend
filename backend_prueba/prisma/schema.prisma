generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role{
  USER
  ADMIN
}

model User {
  id    Int     @id @default(autoincrement())
  email String  
  name  String?
  age Int
  role Role
  createdAt DateTime @default(now())
}
